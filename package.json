{
  "name": "prisma-operation-handler",
  "version": "0.0.1-alpha",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "prisma",
    "handler",
    "utility"
  ],
  "author": "yawpie",
  "license": "ISC",
  "description": "A simple handler for managing Prisma operations",
  "devDependencies": {
    "prisma": "^5.0.0",
    "@types/node": "^22.15.29",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@prisma/client": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": false
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  }
}